{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "label": "odin run . raylib shared",
      "command": "odin",
      "args": [
        "run",
        ".",
        "-define:RAYLIB_SHARED=true"
      ]
    },
    {
      "type": "shell",
      "label": "Make simple_draw",
      "command": "make",
      "args": [
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}/plugins/simple_draw"
      }
    }
  ]
}
